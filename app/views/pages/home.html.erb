<% products_preview = [
  {
    image: "products/go-atendi.png",
    icon: '<i class="fa-solid fa-comments"></i>',
    title: "GO ATendi",
    description: "Uma plataforma criada para centralizar a comunicação da empresa em um único ambiente, conectando canais como WhatsApp, Instagram, Messenger e outros pontos de contato.",
    items: [
      "Atendimento organizado em múltiplos canais",
      "Agentes inteligentes para apoiar triagem e respostas",
      "Histórico, status, métricas e visão mais clara da operação"
    ],
    cta: "Acessar o GO ATendi",
    path: "https://www.goatendi.com.br",
    external: true
  },
  {
    image: "products/devweb.png",
    icon: '<i class="fa-solid fa-layer-group"></i>',
    title: "Soluções digitais sob medida",
    description: "Unimos automações com n8n, desenvolvimento web, integrações e infraestrutura para criar uma base digital mais eficiente para empresas.",
    items: [
      "Automações e integrações para reduzir tarefas manuais",
      "Sites, landing pages e sistemas para presença digital",
      "Estrutura técnica preparada para crescimento e performance"
    ],
    cta: "Ver produtos",
    path: products_path,
    external: false
  }
] %>

<% capabilities = [
  {
    icon: '<i class="fa-solid fa-robot"></i>',
    title: "Atendimento mais inteligente",
    description: "Fluxos automatizados, triagem, respostas assistidas por IA e organização da comunicação com clientes."
  },
  {
    icon: '<i class="fa-solid fa-chart-line"></i>',
    title: "Operação preparada para escala",
    description: "Estruturas digitais que acompanham o crescimento da empresa sem depender apenas de processos manuais."
  },
  {
    icon: '<i class="fa-solid fa-database"></i>',
    title: "Dados e ferramentas conectadas",
    description: "Integrações para reduzir retrabalho, evitar perda de informações e melhorar a tomada de decisão."
  }
] %>

<% blog_posts = [
  {
    image: "blog/devweb-blog.png",
    title: "Desenvolvimento web e presença digital: por que sua empresa precisa de uma base online forte",
    category: "Desenvolvimento web",
    published_at: Date.new(2026, 6, 23),
    excerpt: "Entenda como sites, landing pages e sistemas web ajudam empresas a gerar confiança, captar oportunidades e organizar processos no digital.",
    path: blog_post_path("desenvolvimento-web-presenca-digital-empresas")
  },
  {
    image: "blog/digital-blog.png",
    title: "Estratégia digital para negócios: como organizar processos e evoluir com tecnologia",
    category: "Estratégia digital",
    published_at: Date.new(2026, 6, 23),
    excerpt: "Veja como pequenas melhorias digitais podem gerar ganhos operacionais, reduzir desorganização e preparar empresas para crescer com mais eficiência.",
    path: blog_post_path("estrategia-digital-negocios-operacao-organizada")
  }
] %>

<% hero_impacts = [
  {
    number: "01",
    title: "Presença digital mais forte",
    description: "Sites, páginas e aplicações que comunicam melhor o valor da empresa e criam novas oportunidades."
  },
  {
    number: "02",
    title: "Processos mais eficientes",
    description: "Automações e integrações para reduzir tarefas manuais, retrabalho e perda de informações."
  },
  {
    number: "03",
    title: "Estrutura preparada para crescer",
    description: "Infraestrutura, dados e soluções digitais pensadas para acompanhar a evolução do negócio."
  }
] %>

<% partners = [
  { name: "Clínicas" },
  { name: "E-commerce" },
  { name: "Educação" },
  { name: "Serviços" },
  { name: "Imobiliárias" },
  { name: "Consultorias" },
  { name: "Indústrias" },
  { name: "Tecnologia" },
  { name: "Varejo" },
  { name: "Atendimento" }
] %>

<div class="sollucion-page">
  <div class="bg-pattern"></div>

  <div class="particles" aria-hidden="true">
    <% 22.times do %>
      <span class="particle"></span>
    <% end %>
  </div>

  <div class="glow-lines" aria-hidden="true">
    <span class="glow-line"></span>
    <span class="glow-line"></span>
    <span class="glow-line"></span>
    <span class="glow-line"></span>
    <span class="glow-line"></span>
  </div>

  <main>
    <section class="hero-banner-section">
      <div class="hero-banner">
        <%= image_tag "banner.png", alt: "Sollucion - Automação e integração de sistemas", class: "hero-banner-image" %>
        <div class="hero-banner-overlay"></div>
      </div>
    </section>

    <section class="hero-section">
      <div class="sollucion-container hero-grid hero-grid-single">
        <div class="hero-content">
          <h1>
            Tecnologia para desenvolver empresas no digital com mais eficiência,
            presença e escala.
          </h1>

          <p>
            A Sollucion ajuda pequenos, médios e grandes negócios a evoluírem no
            ambiente digital por meio de produtos digitais, automações, integrações
            e infraestrutura. Nosso foco é simplificar processos que consomem tempo,
            organizar operações e criar soluções tecnológicas que apoiem o crescimento
            da empresa de forma mais inteligente, segura e sustentável.
          </p>

          <div class="hero-points-grid hero-points-inline">
            <% hero_impacts.each do |item| %>
              <article class="hero-highlight-card">
                <span><%= item[:number] %></span>
                <strong><%= item[:title] %></strong>
                <small><%= item[:description] %></small>
              </article>
            <% end %>
          </div>

          <div class="hero-actions">
            <%= link_to "https://wa.me/5500000000000", target: "_blank", rel: "noopener", class: "btn-primary-sollucion" do %>
              <i class="fa-brands fa-whatsapp"></i>
              <span>Fale conosco</span>
            <% end %>

            <%= link_to "Conhecer produtos", products_path, class: "btn-secondary-sollucion" %>
          </div>
        </div>
      </div>
    </section>

    <section class="partners-section">
      <div class="sollucion-container">
        <div class="partners-row">
          <p>Empresas e segmentos que podem evoluir com uma operação mais conectada</p>

          <div class="partners-carousel" aria-label="Segmentos atendidos pela Sollucion">
            <div class="partners-track">
              <div class="partners-group">
                <% partners.each do |partner| %>
                  <article class="partner-card">
                    <span><%= partner[:name] %></span>
                  </article>
                <% end %>
              </div>

              <div class="partners-group" aria-hidden="true">
                <% partners.each do |partner| %>
                  <article class="partner-card">
                    <span><%= partner[:name] %></span>
                  </article>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-block products-preview">
      <div class="sollucion-container">
        <div class="section-heading section-heading-with-action">
          <div>
            <h2>Produtos digitais para estruturar e evoluir sua empresa</h2>

            <p>
              Nossos produtos conectam atendimento, automação, presença digital,
              dados e infraestrutura para criar uma operação mais organizada,
              eficiente e preparada para crescer.
            </p>
          </div>

          <%= link_to "Ver produtos", products_path, class: "btn-secondary-sollucion" %>
        </div>

        <div class="cards-grid home-products-grid">
          <% products_preview.each do |product| %>
            <article class="home-product-card">
              <div class="home-product-media">
                <%= image_tag product[:image], alt: product[:title], class: "home-product-image" %>
                <div class="home-product-media-overlay"></div>

                <div class="home-product-icon">
                  <%= product[:icon].html_safe %>
                </div>
              </div>

              <div class="home-product-content">
                <h3><%= product[:title] %></h3>

                <p><%= product[:description] %></p>

                <ul class="home-product-list">
                  <% product[:items].each do |item| %>
                    <li><%= item %></li>
                  <% end %>
                </ul>

                <% if product[:external] %>
                  <%= link_to product[:path], target: "_blank", rel: "noopener", class: "home-product-link" do %>
                    <span><%= product[:cta] %></span>
                    <i class="fa-solid fa-arrow-right"></i>
                  <% end %>
                <% else %>
                  <%= link_to product[:path], class: "home-product-link" do %>
                    <span><%= product[:cta] %></span>
                    <i class="fa-solid fa-arrow-right"></i>
                  <% end %>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </section>

    <section class="section-block narrative-section">
      <div class="sollucion-container narrative-panel">
        <div class="narrative-copy">
          <h2>Mais do que tecnologia, buscamos gerar valor real para empresas</h2>

          <p>
            Acreditamos que tecnologia deve facilitar a rotina, reduzir complexidade
            e abrir espaço para que empresas foquem no que realmente move o negócio:
            atendimento, vendas, operação, relacionamento e crescimento.
          </p>
        </div>

        <div class="narrative-list">
          <div class="narrative-item">
            <strong>Clareza</strong>
            <span>Produtos objetivos, alinhados ao momento e à necessidade da empresa.</span>
          </div>

          <div class="narrative-item">
            <strong>Eficiência</strong>
            <span>Processos mais leves, menos tarefas manuais e mais organização.</span>
          </div>

          <div class="narrative-item">
            <strong>Evolução</strong>
            <span>Estruturas digitais pensadas para crescer com consistência.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section-block capabilities-section" data-controller="scroll-reveal">
      <div class="sollucion-container">
        <div class="section-heading">
          <h2>O que podemos estruturar para sua operação evoluir</h2>

          <p>
            Em vez de entregar produtos isolados, conectamos presença digital,
            automação, atendimento, dados e infraestrutura para criar uma operação
            mais fluida e preparada para o futuro.
          </p>
        </div>

        <div class="capabilities-list">
          <% capabilities.each_with_index do |item, index| %>
            <article
              class="capability-item scroll-reveal-item"
              data-scroll-reveal-target="item"
              style="--reveal-delay: <%= index * 90 %>ms;"
            >
              <div class="capability-icon">
                <%= item[:icon].html_safe %>
              </div>

              <div>
                <h3><%= item[:title] %></h3>
                <p><%= item[:description] %></p>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </section>

    <section class="section-block blog-preview">
      <div class="sollucion-container">
        <div class="section-heading section-heading-with-action">
          <div>
            <h2>Conteúdos para empresas que querem evoluir no digital</h2>

            <p>
              No blog, explicamos como tecnologia, organização e estratégia podem
              impactar diretamente atendimento, produtividade, presença online,
              infraestrutura e tomada de decisão.
            </p>
          </div>

          <%= link_to "Ver blog", blog_path, class: "btn-secondary-sollucion" %>
        </div>

        <div class="cards-grid home-blog-grid">
          <% blog_posts.each do |post| %>
            <article class="home-blog-card">
              <div class="home-blog-image-wrap">
                <%= image_tag post[:image], alt: post[:title], class: "home-blog-image" %>
              </div>

              <div class="home-blog-content">
                <div class="home-blog-meta">
                  <span class="home-blog-category"><%= post[:category] %></span>
                  <small class="home-blog-date">Publicado em <%= post[:published_at].strftime("%d/%m/%Y") %></small>
                </div>

                <h3><%= post[:title] %></h3>

                <p><%= post[:excerpt] %></p>

                <div class="blog-footer">
                  <small>Conteúdo estratégico</small>

                  <%= link_to post[:path] do %>
                    Ler artigo
                    <i class="fa-solid fa-arrow-right"></i>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </section>

    <section class="section-block contact-section">
      <div class="sollucion-container lead-form-block">
        <div class="section-heading">
          <h2>Vamos conversar sobre o próximo passo do seu negócio?</h2>

          <p>
            Se você busca melhorar presença digital, automatizar processos,
            estruturar sua operação ou evoluir a base tecnológica da empresa,
            a Sollucion pode te ajudar.
          </p>

          <div class="contact-info contact-info-grid">
            <a href="https://wa.me/5500000000000" target="_blank" rel="noopener" class="contact-item contact-card">
              <span class="contact-icon">
                <i class="fa-brands fa-whatsapp"></i>
              </span>

              <span class="contact-copy">
                <small>WhatsApp</small>
                <strong>Fale com a Sollucion</strong>
              </span>
            </a>

            <a href="mailto:contato@sollucion.com" class="contact-item contact-card">
              <span class="contact-icon">
                <i class="fa-regular fa-envelope"></i>
              </span>

              <span class="contact-copy">
                <small>E-mail</small>
                <strong>contato@sollucion.com</strong>
              </span>
            </a>

            <a href="https://www.instagram.com/sollucion.ltda?igsh=cmg2d3dzamF3eTgz" target="_blank" rel="noopener" class="contact-item contact-card">
              <span class="contact-icon">
                <i class="fa-brands fa-instagram"></i>
              </span>

              <span class="contact-copy">
                <small>Instagram</small>
                <strong>Sollucion</strong>
              </span>
            </a>

            <div class="contact-item contact-card">
              <span class="contact-icon">
                <i class="fa-solid fa-location-dot"></i>
              </span>

              <span class="contact-copy">
                <small>Endereço</small>
                <strong>São Paulo - SP</strong>
              </span>
            </div>
          </div>
        </div>

        <form action="#" method="post" class="lead-form">
          <div class="lead-grid">
            <label class="field">
              <span>Nome</span>
              <input type="text" name="name" placeholder="Seu nome">
            </label>

            <label class="field">
              <span>Empresa</span>
              <input type="text" name="company" placeholder="Nome da empresa">
            </label>

            <label class="field">
              <span>E-mail</span>
              <input type="email" name="email" placeholder="voce@empresa.com">
            </label>

            <label class="field">
              <span>WhatsApp</span>
              <input type="tel" name="phone" placeholder="(00) 00000-0000">
            </label>
          </div>

          <label class="field field-full">
            <span>Interesse</span>

            <select name="interest">
              <option value="">Selecione uma opção</option>
              <option>Automações com n8n</option>
              <option>Desenvolvimento web</option>
              <option>Integração entre sistemas</option>
              <option>Infraestrutura digital</option>
              <option>Outro</option>
            </select>
          </label>

          <label class="field field-full">
            <span>Mensagem</span>

            <textarea name="message" rows="5" placeholder="Conte brevemente o que sua empresa precisa..."></textarea>
          </label>

          <div class="lead-actions">
            <button type="submit" class="lead-btn lead-btn-email">
              Enviar mensagem
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <%= render "shared/footer" %>

  <a href="https://wa.me/5500000000000" target="_blank" rel="noopener" class="whatsapp-float" aria-label="Fale conosco no WhatsApp">
    <i class="fa-brands fa-whatsapp"></i>
  </a>
</div>
